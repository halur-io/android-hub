{% extends "base.html" %}

{% block title %}צור קשר - מסעדת סומו{% endblock %}

{% block content %}
<!-- Contact Hero -->
<section class="page-hero bg-primary text-white">
    <div class="container">
        <div class="row text-center">
            <div class="col-lg-8 mx-auto">
                <h1 class="display-4 mb-3">
                    {% if reservation %}הזמנת שולחן{% else %}צור קשר{% endif %}
                </h1>
                <p class="lead">
                    {% if reservation %}
                        הזמינו שולחן ותיהנו מחוויה קולינרית בלתי נשכחת
                    {% else %}
                        נשמח לשמוע מכם ולענות על כל שאלה
                    {% endif %}
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Form Section -->
<section class="contact-form-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="contact-form-card">
                    <form method="POST" class="needs-validation" novalidate>
                        {{ form.hidden_tag() }}
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form.name.label(class="form-label") }}
                                {{ form.name(class="form-control" + (" is-invalid" if form.name.errors else "")) }}
                                {% if form.name.errors %}
                                    <div class="invalid-feedback">
                                        {% for error in form.name.errors %}{{ error }}{% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                {{ form.email.label(class="form-label") }}
                                {{ form.email(class="form-control" + (" is-invalid" if form.email.errors else "")) }}
                                {% if form.email.errors %}
                                    <div class="invalid-feedback">
                                        {% for error in form.email.errors %}{{ error }}{% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form.phone.label(class="form-label") }}
                                {{ form.phone(class="form-control" + (" is-invalid" if form.phone.errors else "")) }}
                                {% if form.phone.errors %}
                                    <div class="invalid-feedback">
                                        {% for error in form.phone.errors %}{{ error }}{% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {% if reservation %}
                                <div class="col-md-6 mb-3">
                                    {{ form.guests.label(class="form-label") }}
                                    {{ form.guests(class="form-control" + (" is-invalid" if form.guests.errors else "")) }}
                                    {% if form.guests.errors %}
                                        <div class="invalid-feedback">
                                            {% for error in form.guests.errors %}{{ error }}{% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                        
                        {% if reservation %}
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    {{ form.date.label(class="form-label") }}
                                    {{ form.date(class="form-control" + (" is-invalid" if form.date.errors else "")) }}
                                    {% if form.date.errors %}
                                        <div class="invalid-feedback">
                                            {% for error in form.date.errors %}{{ error }}{% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    {{ form.time.label(class="form-label") }}
                                    {{ form.time(class="form-control" + (" is-invalid" if form.time.errors else "")) }}
                                    {% if form.time.errors %}
                                        <div class="invalid-feedback">
                                            {% for error in form.time.errors %}{{ error }}{% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                        
                        <div class="mb-3">
                            {% if reservation %}
                                {{ form.special_requests.label(class="form-label") }}
                                {{ form.special_requests(class="form-control", rows="4", placeholder="אלרגיות, העדפות מיוחדות וכו'...") }}
                            {% else %}
                                {{ form.message.label(class="form-label") }}
                                {{ form.message(class="form-control" + (" is-invalid" if form.message.errors else ""), rows="4", placeholder="כתבו כאן את הודעתכם...") }}
                                {% if form.message.errors %}
                                    <div class="invalid-feedback">
                                        {% for error in form.message.errors %}{{ error }}{% endfor %}
                                    </div>
                                {% endif %}
                            {% endif %}
                        </div>
                        
                        <div class="text-center">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-{% if reservation %}calendar-check{% else %}paper-plane{% endif %} me-2"></i>
                                {% if reservation %}הזמנת השולחן{% else %}שליחת הודעה{% endif %}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Info Section -->
{% if not reservation %}
<section class="contact-info-section py-5 bg-light">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-lg-8 mx-auto">
                <h2 class="section-title">פרטי קשר</h2>
                <p class="section-subtitle">כל המידע שאתם צריכים כדי להגיע אלינו</p>
            </div>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="contact-info-card text-center">
                    <div class="contact-icon">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <h4>כתובת</h4>
                    <p>רחוב הרצל 123<br>תל אביב-יפו, 6789012</p>
                    <a href="https://maps.google.com" class="btn btn-outline-primary btn-sm" target="_blank">
                        <i class="fas fa-directions me-1"></i>
                        הוראות הגעה
                    </a>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="contact-info-card text-center">
                    <div class="contact-icon">
                        <i class="fas fa-phone"></i>
                    </div>
                    <h4>טלפון</h4>
                    <p>הזמנות ופניות כלליות</p>
                    <a href="tel:03-1234567" class="btn btn-primary btn-sm">
                        <i class="fas fa-phone me-1"></i>
                        03-1234567
                    </a>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="contact-info-card text-center">
                    <div class="contact-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <h4>שעות פעילות</h4>
                    <p>ראשון - חמישי: 12:00 - 23:00<br>
                       שישי - שבת: 12:00 - 01:00</p>
                    <small class="text-muted">משלוחים עד 22:30</small>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Map Section -->
<section class="map-section">
    <div class="map-container">
        <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3380.344!2d34.774!3d32.066!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzLCsDA0JzAwLjAiTiAzNMKwNDYnMjcuNiJF!5e0!3m2!1sen!2sil!4v1234567890"
            width="100%" 
            height="400" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
        </iframe>
    </div>
</section>
{% endif %}
{% endblock %}

{% block scripts %}
<script>
// Form validation
(function() {
    'use strict';
    window.addEventListener('load', function() {
        var forms = document.getElementsByClassName('needs-validation');
        var validation = Array.prototype.filter.call(forms, function(form) {
            form.addEventListener('submit', function(event) {
                if (form.checkValidity() === false) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
    }, false);
})();

// Set minimum date to today for reservation form
{% if reservation %}
document.addEventListener('DOMContentLoaded', function() {
    var dateInput = document.getElementById('date');
    if (dateInput) {
        var today = new Date().toISOString().split('T')[0];
        dateInput.setAttribute('min', today);
    }
});
{% endif %}
</script>
{% endblock %}
