                    <p class="gallery-caption">אווירה מודרנית ומזמינה</p>
                </div>
            </div>
            
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600" alt="פינת ישיבה">
