<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" width="300" height="300">
  <defs>
    <!-- Define gradients and colors -->
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#1B2951;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0F1A33;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Outer Circle (Coral) -->
  <rect x="0" y="0" width="300" height="300" fill="#C75450"/>
  
  <!-- Inner Circle (Navy) -->
  <circle cx="150" cy="150" r="120" fill="url(#bgGradient)" stroke="#F5F5F0" stroke-width="8"/>
  
  <!-- Top Text: ASIAN KITCHEN -->
  <path id="topCircle" d="M 150,150 m -90,0 a 90,90 0 0,1 180,0" fill="none"/>
  <text font-family="Heebo, Arial, sans-serif" font-size="18" font-weight="700" fill="#F5F5F0" letter-spacing="4">
    <textPath href="#topCircle" startOffset="50%" text-anchor="middle">ASIAN KITCHEN</textPath>
  </text>
  
  <!-- Sumo Character (Simplified) -->
  <g transform="translate(150, 150)">
    <!-- Hair bun -->
    <ellipse cx="0" cy="-40" rx="15" ry="12" fill="#0A0F1F"/>
    
    <!-- Head -->
    <circle cx="0" cy="-10" r="30" fill="#E8D4B0"/>
    
    <!-- Eyes -->
    <path d="M -12,-15 Q -8,-18 -4,-15" fill="none" stroke="#0A0F1F" stroke-width="2" stroke-linecap="round"/>
    <path d="M 4,-15 Q 8,-18 12,-15" fill="none" stroke="#0A0F1F" stroke-width="2" stroke-linecap="round"/>
    
    <!-- Smile -->
    <path d="M -10,-5 Q 0,0 10,-5" fill="none" stroke="#0A0F1F" stroke-width="2" stroke-linecap="round"/>
    
    <!-- Body -->
    <ellipse cx="0" cy="25" rx="45" ry="40" fill="#E8D4B0"/>
    
    <!-- Arms -->
    <ellipse cx="-35" cy="20" rx="18" ry="25" fill="#E8D4B0" transform="rotate(-20 -35 20)"/>
    <ellipse cx="35" cy="20" rx="18" ry="25" fill="#E8D4B0" transform="rotate(20 35 20)"/>
    
    <!-- Bowl -->
    <ellipse cx="0" cy="35" rx="25" ry="12" fill="#FFFFFF"/>
    <ellipse cx="0" cy="33" rx="23" ry="10" fill="#DC3545"/>
    
    <!-- Chopsticks -->
    <line x1="-5" y1="30" x2="-8" y2="10" stroke="#8B4513" stroke-width="2" stroke-linecap="round"/>
    <line x1="5" y1="30" x2="8" y2="10" stroke="#8B4513" stroke-width="2" stroke-linecap="round"/>
    
    <!-- Noodles in bowl -->
    <path d="M -15,33 Q -10,38 -5,33 Q 0,38 5,33 Q 10,38 15,33" fill="none" stroke="#FFF8DC" stroke-width="1.5" opacity="0.8"/>
  </g>
  
  <!-- Bottom Text: SUMO -->
  <text x="150" y="240" font-family="Heebo, Arial, sans-serif" font-size="36" font-weight="900" fill="#F5F5F0" text-anchor="middle" letter-spacing="8">SUMO</text>
  
  <!-- Decorative dots -->
  <circle cx="80" cy="150" r="6" fill="#C75450"/>
  <circle cx="220" cy="150" r="6" fill="#C75450"/>
</svg>