{% extends "base.html" %}

{% block title %}אודות - מסעדת סומו{% endblock %}

{% block content %}
<!-- About Hero -->
<section class="page-hero bg-primary text-white">
    <div class="container">
        <div class="row text-center">
            <div class="col-lg-8 mx-auto">
                <h1 class="display-4 mb-3">אודות סומו</h1>
                <p class="lead">הסיפור שלנו והחזון מאחורי המסעדה</p>
            </div>
        </div>
    </div>
</section>

<!-- Story Section -->
<section class="story-section py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="story-content">
                    <h2 class="section-title mb-4">הסיפור שלנו</h2>
                    <p class="lead mb-4">מסעדת סומו נוסדה מתוך אהבה עמוקה למטבח האסייאתי ורצון להביא לישראל את הטעמים האותנטיים של מזרח אסיה.</p>
                    
                    <p class="mb-4">השף הראשי שלנו, עם ניסיון של מעל 15 שנה במטבחים אסייאתיים מובילים ברחבי העולם, החליט לפתוח כאן בתל אביב מקום שבו יוכל לשתף את התשוקה שלו לקולינריה אסייאתית אותנטית.</p>
                    
                    <p class="mb-4">אנחנו מאמינים שאוכל טוב מחבר בין תרבויות ואנשים, ולכן בחרנו להציע מגוון רחב של מטבחים - יפני, תאילנדי, קוריאני וויאטנמי - הכל תחת קורת גג אחת.</p>
                    
                    <div class="story-highlights">
                        <div class="highlight-item mb-2">
                            <i class="fas fa-award text-primary me-2"></i>
                            <strong>חומרי גלם מובחרים</strong> - מיבוא ישיר מאסיה
                        </div>
                        <div class="highlight-item mb-2">
                            <i class="fas fa-heart text-primary me-2"></i>
                            <strong>הכנה בעבודת יד</strong> - כל מנה מוכנת עם אהבה
                        </div>
                        <div class="highlight-item mb-2">
                            <i class="fas fa-leaf text-primary me-2"></i>
                            <strong>טרי ואיכותי</strong> - מקפידים על רכיבים טריים מדי יום
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6">
                <div class="story-image">
                    <img src="https://pixabay.com/get/g152464fedb6610c1ea76f25248f51077e5a73d6cbdf8ae999a2e697236816592b63470c45c8dab202da3621182ead09c5bf2d8861379b8f5db8c509383c0d062_1280.jpg" class="img-fluid rounded shadow" alt="מטבח המסעדה">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="values-section py-5 bg-light">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-lg-8 mx-auto">
                <h2 class="section-title">הערכים שלנו</h2>
                <p class="section-subtitle">מה שמנחה אותנו בכל יום</p>
            </div>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="value-card text-center">
                    <div class="value-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <h4>איכות ללא פשרות</h4>
                    <p>אנחנו מקפידים על הסטנדרטים הגבוהים ביותר בכל מה שנוגע לחומרי גלם, הכנת המנות ושירות לקוחות.</p>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="value-card text-center">
                    <div class="value-icon">
                        <i class="fas fa-globe-asia"></i>
                    </div>
                    <h4>אותנטיות תרבותית</h4>
                    <p>אנחנו מכבדים את המסורות הקולינריות של כל מטבח ומקפידים על הכנה אותנטית לפי המתכונים המקוריים.</p>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="value-card text-center">
                    <div class="value-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4>חוויה משפחתית</h4>
                    <p>אנחנו רוצים שכל לקוח ירגיש כמו בבית, עם שירות חם ואישי שיגרום לכם לחזור שוב ושוב.</p>
                </div>
            </div>
        </div>
    </div>
</section>

